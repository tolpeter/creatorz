# =============================================================================
# Creatorz – környezeti változók
# -----------------------------------------------------------------------------
# Helyi fejlesztés:  másold .env.local-ba és töltsd ki (DEV Supabase + Stripe TEST).
# Vercel Production: a PROD Supabase + Stripe LIVE kulcsokat a Vercel
#   Settings → Environment Variables → "Production" alá tedd.
# Vercel Preview:    a DEV Supabase + Stripe TEST kulcsokat a "Preview" alá.
# [KÖTELEZŐ] = élesben enélkül nem indul / nem működik a funkció.
# =============================================================================

# Supabase  [KÖTELEZŐ]
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# DATABASE_URL: a Supabase "Transaction pooler" (6543) connection string,
# ?pgbouncer=true&connection_limit=1 nélkül is jó (a kód prepare:false-szal fut).

# Stripe (Test mode kulcsok kezdéskor)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_FEATURE_7DAY=
STRIPE_PRICE_FEATURE_30DAY=

# Resend
RESEND_API_KEY=
EMAIL_FROM=Creatorz <hello@creatorz.hu>

# Replicate (kép-generáláshoz)
REPLICATE_API_TOKEN=

# Social (opcionális, follower scrape-hez)
YOUTUBE_API_KEY=
META_GRAPH_API_TOKEN=

# OpenAI API — AI követőszám-extrakció + AI blog-generálás.
# Ha nincs megadva: csak regex scraping fut, és a blog-cron nem készít posztot.
# Kulcs: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcionális: a blog-generálás modellje (alapért. gpt-4o-mini).
BLOG_AI_MODEL=gpt-4o-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Creatorz

# Analitika (opcionális) — Consent Mode v2-vel, csak hozzájárulás után mér.
# Elég az egyiket megadni; ha üresen hagyod, semmilyen analytics nem töltődik be.
#  - Közvetlen Google Analytics 4:  GA Admin → Adatfolyamok → "G-" kezdetű mérési azonosító
#  - Google Tag Manager konténer:   GTM → "GTM-" kezdetű konténer-azonosító
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=

# Facebook (Meta) Pixel — FB/Instagram hirdetes-konverziomeres (pl. regisztracio).
#  - Meta Events Manager → Adatforrasok → a Pixel azonositoja (szamsor).
#  - Ha uresen hagyod, a pixel nem toltodik be.
#  - Csak marketing-suti hozzajarulas utan mer (GDPR).
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Admin (induló admin email — később adatbázisban kezelve)
ADMIN_EMAIL=

# Cron secret (Vercel Cron biztosításához — generálj erős random stringet)
CRON_SECRET=

# Feature flags (admin által módosítható, de default érték itt)
NEXT_PUBLIC_CREATOR_SUBSCRIPTION_ENABLED=false
NEXT_PUBLIC_CREATOR_SUBSCRIPTION_PRICE_HUF=2990
NEXT_PUBLIC_FEATURE_7DAY_PRICE_HUF=4990
NEXT_PUBLIC_FEATURE_30DAY_PRICE_HUF=12990
