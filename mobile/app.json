{
  "expo": {
    "name": "Creatorz",
    "slug": "creatorz",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "creatorz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "hu.creatorz.app",
      "associatedDomains": ["applinks:www.creatorz.hu", "applinks:creatorz.hu"]
    },
    "android": {
      "package": "hu.creatorz.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "www.creatorz.hu", "pathPrefix": "/creators" },
            { "scheme": "https", "host": "www.creatorz.hu", "pathPrefix": "/ads" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
