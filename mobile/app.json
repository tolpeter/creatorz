{
  "expo": {
    "name": "Creatorz",
    "slug": "creatorz",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "creatorz",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "hu.creatorz.app"
    },
    "android": {
      "package": "hu.creatorz.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
