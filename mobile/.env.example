# Másold .env-be, és töltsd ki a Supabase és az API adatokkal.
# (Ugyanaz az URL + anon kulcs, mint a webnél — ezek publikus, RLS-védett kulcsok.)
EXPO_PUBLIC_SUPABASE_URL=https://<projekt>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# A web API címe (creator-lista stb.)
EXPO_PUBLIC_API_URL=https://creatorz.hu
